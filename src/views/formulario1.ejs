<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Crear Formulario</title>
    <style>
        body { font-family: Arial; margin: 20px; }
        .campo { margin-bottom: 10px; padding: 10px; border: 1px solid #ccc; }
        button { margin-top: 10px; }
    </style>
</head>
<body>

<h2>Crear Formulario</h2>

<form action="/guardar-formulario" method="POST">
    
    <label>Nombre del formulario:</label><br>
    <input type="text" name="titulo" required><br><br>

    <div id="campos"></div>

    <button type="button" onclick="agregarCampo()">Agregar Campo</button><br><br>

    <button type="submit">Guardar Formulario</button>
</form>

<script>
let contador = 0;

function agregarCampo() {
    const div = document.createElement('div');
    div.classList.add('campo');

    div.innerHTML = `
        <label>Pregunta:</label><br>
        <input type="text" name="campos[${contador}][label]" required><br>

        <label>Tipo:</label><br>
        <select name="campos[${contador}][tipo]">
            <option value="text">Texto</option>
            <option value="number">Número</option>
            <option value="email">Email</option>
            <option value="date">Fecha</option>
        </select><br>

        <button type="button" onclick="this.parentElement.remove()">Eliminar</button>
    `;

    document.getElementById('campos').appendChild(div);
    contador++;
}
</script>

</body>
</html>