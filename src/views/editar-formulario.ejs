<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Formulario</title>

    <style>
        body { font-family: Arial; margin: 20px; }

        .campo {
            border: 1px solid #ccc;
            padding: 12px;
            margin-bottom: 12px;
            border-radius: 6px;
            background: #f9f9f9;
        }

        textarea {
            width: 100%;
            resize: none;
            overflow: hidden;
            min-height: 60px;
            font-family: Arial;
        }

        select {
            margin-top: 5px;
        }

        button {
            margin-top: 8px;
            padding: 6px 10px;
            cursor: pointer;
        }

        .btn-eliminar {
            background: #dc3545;
            color: white;
            border: none;
        }

        .btn-agregar {
            background: #28a745;
            color: white;
            border: none;
        }

        .btn-guardar {
            background: #007bff;
            color: white;
            border: none;
        }
    </style>
</head>
<body>

<h2>Editar Formulario</h2>

<form action="/actualizar-formulario/<%= formulario._id %>" method="POST">

    <label><strong>Título:</strong></label><br>
    <input type="text" name="titulo" value="<%= formulario.titulo %>" style="width:100%;" required>
    <br><br>

    <h3>Campos:</h3>

    <div id="campos">

        <% formulario.campos.forEach((campo, index) => { %>
            <div class="campo">

                <label>Pregunta:</label><br>
                <textarea 
                    name="campos[<%= index %>][label]" 
                    oninput="autoResize(this)" 
                    required><%= campo.label %></textarea>

                <label>Tipo:</label><br>
                <select name="campos[<%= index %>][tipo]">
                    <option value="text" <%= campo.tipo === 'text' ? 'selected' : '' %>>Texto</option>
                    <option value="number" <%= campo.tipo === 'number' ? 'selected' : '' %>>Número</option>
                    <option value="email" <%= campo.tipo === 'email' ? 'selected' : '' %>>Email</option>
                    <option value="date" <%= campo.tipo === 'date' ? 'selected' : '' %>>Fecha</option>
                </select><br>

                <button type="button" class="btn-eliminar" onclick="this.parentElement.remove()">
                    Eliminar
                </button>

            </div>
        <% }) %>

    </div>

    <button type="button" class="btn-agregar" onclick="agregarCampo()">
        ➕ Agregar Campo
    </button>

    <br><br>

    <button type="submit" class="btn-guardar">
        💾 Actualizar Formulario
    </button>

</form>

<script>
let contador = <%= formulario.campos.length %>;

// Auto ajustar altura del textarea
function autoResize(textarea) {
    textarea.style.height = 'auto';
    textarea.style.height = textarea.scrollHeight + 'px';
}

// Aplicar auto resize al cargar
document.querySelectorAll('textarea').forEach(t => autoResize(t));

// Agregar campo dinámico
function agregarCampo() {
    const div = document.createElement('div');
    div.classList.add('campo');

    div.innerHTML = `
        <label>Pregunta:</label><br>
        <textarea 
            name="campos[${contador}][label]" 
            oninput="autoResize(this)" 
            required></textarea>

        <label>Tipo:</label><br>
        <select name="campos[${contador}][tipo]">
            <option value="text">Texto</option>
            <option value="number">Número</option>
            <option value="email">Email</option>
            <option value="date">Fecha</option>
        </select><br>

        <button type="button" class="btn-eliminar" onclick="this.parentElement.remove()">
            Eliminar
        </button>
    `;

    document.getElementById('campos').appendChild(div);
    contador++;
}
</script>

</body>
</html>