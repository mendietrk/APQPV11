<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Videoteca</title>

<style>
body{
    background:#0f0f0f;
    color:#fff;
    font-family:Arial, Helvetica, sans-serif;
    margin:0;
    padding:20px;
}

h1{
    text-align:center;
    margin-bottom:30px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(400px,1fr));
    gap:25px;
}

.card{
    background:#1b1b1b;
    border-radius:12px;
    padding:15px;
    box-shadow:0 0 10px rgba(255,255,255,0.08);
}

.card h2{
    margin-top:0;
    color:#e50914;
}

video{
    width:100%;
    border-radius:8px;
    background:#000;
}
</style>
</head>
<body>

<h1>Mi Biblioteca de Videos</h1>

<div class="grid">

    <div class="card">
        <h2>Chernobil</h2>
        <video controls preload="metadata">
            <source src="https://www.mendietr.com/1.mp4" type="video/mp4">
            Tu navegador no soporta video HTML5.
        </video>
    </div>

    <div class="card">
        <h2>Un Show Más</h2>
        <video controls preload="metadata">
            <source src="https://www.mendietr.com/2.mp4" type="video/mp4">
            Tu navegador no soporta video HTML5.
        </video>
    </div>

    <div class="card">
        <h2>Hannibal: El Origen</h2>
        <video controls preload="metadata">
            <source src="https://www.mendietr.com/3.mp4" type="video/mp4">
            Tu navegador no soporta video HTML5.
        </video>
    </div>

    <div class="card">
        <h2>Hannibal</h2>
        <video controls preload="metadata">
            <source src="https://www.mendietr.com/4.mp4" type="video/mp4">
            Tu navegador no soporta video HTML5.
        </video>
    </div>

</div>

</body>
</html>